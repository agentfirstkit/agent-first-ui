        "label": "Brush stroke on Photo"
      },
      {
        "id": "h3",
        "label": "Opacity 100 -> 85 on Photo"
      }
    ],
    "document": {
      "path": "~/projects/poster.psd",
      "dirty": true,
      "saved_at_epoch_ms": 1778800000000
    }
  }
}
